ROCKET_PROFILE=production
OTEL_ENVIRONMENT=production
CONFIG_PATH=/app/config
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
RUST_LOG=info,sqlx=info,rocket=info
DATABASE_URL=/app/data/sqlite.db
SQLX_OFFLINE=true
SSL_CERT_EMAIL=mail@matthewtapps.com

VITE_API_URL=/api
VITE_ENVIRONMENT=production

# Flip to true once the R2 bucket is provisioned and creds are in
# .secrets.env. While false, the video routes are not mounted, no S3 client is
# constructed, and the frontend hides the upload UI via /api/capabilities.
VIDEOS_ENABLED=true

# Cloudflare R2 (S3-compatible). Credentials in .secrets.env.
S3_ENDPOINT=https://ea9e8573831e597fc41f865267b8fd35.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=sillybus-videos-prod

# Litestream replication target. Separate R2 bucket from videos, with its own
# scoped API token in .secrets.env (LITESTREAM_ACCESS_KEY_ID,
# LITESTREAM_SECRET_ACCESS_KEY). Same R2 account endpoint as S3_ENDPOINT.
LITESTREAM_ENDPOINT=https://ea9e8573831e597fc41f865267b8fd35.r2.cloudflarestorage.com
LITESTREAM_BUCKET=sillybus-db-backups-prod
