ROCKET_PROFILE=production
OTEL_ENVIRONMENT=production
CONFIG_PATH=/app/config
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
RUST_LOG=info,sqlx=info,rocket=info
DATABASE_URL=/app/data/sqlite.db
SQLX_OFFLINE=true
SSL_CERT_EMAIL=mail@matthewtapps.com

VITE_API_URL=/api
VITE_ENVIRONMENT=production

# Flip to true once Hetzner Object Storage is provisioned and creds are in
# .secrets.env. While false, the video routes are not mounted, no S3 client is
# constructed, and the frontend hides the upload UI via /api/capabilities.
VIDEOS_ENABLED=false

# Hetzner Object Storage. Credentials in .secrets.env.
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=syllabus-tracker-videos-prod
