# OpenTelemetry
OTEL_SERVICE_NAME=syllabus-tracker
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Frontend
VITE_APP_NAME="Syllabus Tracker"

# Schema
SCHEMA_PATH=config/schema.sql

# Video uploads. FFMPEG_BIN/FFPROBE_BIN default to PATH lookup; the production
# Dockerfile pins them to absolute paths.
VIDEO_UPLOAD_TEMP_DIR=/tmp/syllabus/uploads
VIDEO_MAX_BYTES=209715200
VIDEO_MAX_DURATION_SECONDS=300
# Concurrent ffmpeg transcodes. 1 = process uploads serially so a burst does
# not saturate the web host's CPU. Raise once transcoding is off-host.
VIDEO_TRANSCODE_CONCURRENCY=1
VIDEO_PLAYBACK_URL_TTL_SECONDS=3600
VIDEO_DOWNLOAD_URL_TTL_SECONDS=600
# Transcode backend: "host" (in-process ffmpeg, capped by the semaphore
# above) or "remote" (offload to an off-host HTTP transcode endpoint, e.g.
# Cloud Run; requires VIDEO_ENQUEUE_URL/TOKEN, VIDEO_CALLBACK_SECRET,
# VIDEO_CALLBACK_BASE_URL).
# Default host everywhere; staging cuts over via the staging.yml override,
# prod stays host until an explicit, separate cutover.
VIDEO_PROCESSOR=host
# Seconds before the remote-path sweeper fails a row stuck "processing".
VIDEO_PROCESSING_TIMEOUT_SECONDS=1800

# Object storage
S3_FORCE_PATH_STYLE=true
