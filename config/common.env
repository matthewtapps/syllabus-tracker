# OpenTelemetry
OTEL_SERVICE_NAME=syllabus-tracker
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Frontend
VITE_APP_NAME="Syllabus Tracker"

# Schema
SCHEMA_PATH=config/schema.sql

# Video uploads
VIDEO_UPLOAD_TEMP_DIR=/tmp/syllabus/uploads
VIDEO_MAX_BYTES=209715200
VIDEO_MAX_DURATION_SECONDS=180
VIDEO_PLAYBACK_URL_TTL_SECONDS=3600
VIDEO_DOWNLOAD_URL_TTL_SECONDS=600
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Object storage
S3_FORCE_PATH_STYLE=true
