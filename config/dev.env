ROCKET_PROFILE=dev
RUST_LOG=info
DATABASE_URL=sqlite://sqlite.db

CONFIG_PATH=./config

OTEL_ENVIRONMENT=development
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

VITE_API_URL=http://localhost:8000/api
VITE_ENVIRONMENT=development

VIDEOS_ENABLED=true

# Local MinIO bucket. Real R2 creds belong in .secrets.env for prod.
# S3_ENDPOINT is what the app uses inside the docker network (PUT/GET).
# S3_PUBLIC_ENDPOINT is what the browser hits, embedded in presigned URLs.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=syllabus-tracker-videos-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
