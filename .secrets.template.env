HONEYCOMB_API_KEY=your-honeycomb-key
ROCKET_SECRET_KEY=your-rocket-secret
# Cloudflare API token used by `just tf` to provision/manage R2.
# Generate at https://dash.cloudflare.com/profile/api-tokens with
# `Workers R2 Storage` policy (Read + Edit).
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# GitHub PAT used by `just tf` to manage repo Actions secrets.
# Generate a fine-scoped token at https://github.com/settings/personal-access-tokens
# with `Actions: Read and write` on syllabus-tracker only.
GITHUB_TOKEN=your-github-pat
